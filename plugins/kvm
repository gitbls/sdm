function makenmconn() {
    cname="$1" makeif="$2" nmcmd="$3" nmx="$4"

    if [ -f /etc/NetworkManager/system-connections/$cname.nmconnection ]
    then
	logtoboth "% Plugin $pfx: NetworkManager connection $cname already exists; Deleting prior definition"
	rm -f /etc/NetworkManager/system-connections/$cname.nmconnection
    fi
    logtoboth "> Plugin $pfx: Create connection '$cname' on interface '$makeif'"
    if [ "$nminclude" == "" ]
    then
	bash -c "nmcli --offline $nmcmd | tee /etc/NetworkManager/system-connections/$cname.nmconnection >/dev/null"
    else
	bash -c "cat /etc/NetworkManager/system-connections/$nmx.nmconnection | nmcli --offline $nmcmd | tee /etc/NetworkManager/system-connections/$cname.nmconnection >/dev/null"
    fi
    sts=$?
    [ $sts -ne 0 ] && logtobothex "? Plugin $pfx: nmcli returned error '$sts' on create connection '$cname' with '$nmcmd'"
    chmod 600 /etc/NetworkManager/system-connections/$cname.nmconnection
}

# $1 is the phase: "0", "1", or "post-install"
# $2 is the argument list: arg1=val1|arg2=val2|arg3=val3| ...
#
# Main code for the Plugin
#
phase=$1
pfx="$(basename $0)"     #For messages
args="$2"
loadparams

#vldargs="|bridge-add-config|bridge-slave-add-config|ifname|user|"
vldargs="|gui|ifname|user|"
rqdargs=""
assetdir="$SDMPT/etc/sdm/assets/$pfx"

if [ "$phase" == "0" ]
then
    #
    # In Phase 0 all references to directories in the image must be preceded by $SDMPT
    #
    logtoboth "* Plugin $pfx: Start Phase 0"
    plugin_getargs $pfx "$args" "$vldargs" "$rqdargs" || exit
    plugin_printkeys
    mkdir -p $assetdir

    logtoboth "* Plugin $pfx: Complete Phase 0"
elif [ "$phase" == "1" ]
then
    #
    # Phase 1 (in nspawn)
    #
    logtoboth "* Plugin $pfx: Start Phase 1"
    plugin_getargs $pfx "$args" "$vldargs" "$rqdargs"
    logfreespace "at start of Plugin $pfx Phase 1"
    pkgs="ipxe-qemu libvirt-clients libvirt-daemon-system qemu-efi-aarch64 qemu-system-arm qemu-utils virt-install virt-viewer xorriso"
    [ -v gui ] && pkgs="$pkgs virt-manager"
    logtoboth "> Plugin $pfx: Install required packages: $pkgs"
    installpkgsif "$pkgs"
    [ "$user" == "" ] && user=$myuser
    if [ "$user" != "" ]
    then
	logtoboth "> Plugin $pfx: Add user '$user' to groups libvirt and libvirt-qemu"
	usermod -a -G libvirt $user
	usermod -a -G libvirt-qemu $user
    else
	logtoboth "% Plugin $pfx: No user provided; Use 'usermod -a -G' to add designated user to libvirt and libvirt-qemu groups if desired" nosplit
    fi
    logfreespace "at end of Plugin $pfx Phase 1"
    logtoboth "* Plugin $pfx: Complete Phase 1"
elif [ "$phase" == "post-install" ]
then
    #
    # Plugin Post-install edits
    #
    logtoboth "* Plugin $pfx: Start Phase post-install"
    plugin_getargs $pfx "$args" "$vldargs" "$rqdargs"
    bname=br0
    fwdev=${ifname:-eth0}
    #
    # Disable connection using $fwdev if present
    #
    if grep -qs interface-name=$fwdev /etc/NetworkManager/system-connections/*.nmconnection
    then
	excname=$(grep -l interface-name=$fwdev /etc/NetworkManager/system-connections/*.nmconnection 2>/dev/null)
	if [ "$excname" != "" ]
	then
	    excnamefn="$(basename $excname)"
	    IFS="=" read x id <<< $(grep id= $excname)
	    [ "$id" == "" ] && id="${excnamefn%.nmconnection}"
	    logtoboth "> Plugin $pfx: Disable connection '$id' in favor of bridged network"
	    logtoboth "  by dot-renaming '$excname'"
	    mv /etc/NetworkManager/system-connections/$excnamefn /etc/NetworkManager/system-connections/.sdm.$excnamefn
	fi
    fi
    logtoboth "> Plugin $pfx: Create bridge '$bname' and bridge slave '$bname-slave-$fwdev'"
    nmcmd="c add ifname $bname type bridge con-name $bname bridge.stp no ipv6.method disabled connection.autoconnect-slaves 1 autoconnect yes connection.autoconnect-priority 101"
    makenmconn $bname $fwdev "$nmcmd"
    chmod 600 /etc/NetworkManager/system-connections/$bname.nmconnection
    nmcmd="c add type bridge-slave ifname $fwdev con-name $bname-slave-$fwdev master $bname autoconnect yes | grep -v 'any existing profile'"
    # pass $bname (4th arg) into the nmcli --offline command to prevent this to stdout: "Warning: controller='br0' doesn't refer to any existing profile."
    makenmconn $bname-slave-$fwdev $bname "$nmcmd" $bname

    logtoboth "> Plugin $pfx: Add kvm scripts to $sdmdir/kvm"
    writekvmscripts
    logtoboth "* Plugin $pfx: Complete Phase post-install"
fi
exit
